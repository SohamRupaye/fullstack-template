{
  "compilerOptions": {
    "target": "esnext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "outDir": "dist",
    "skipLibCheck": true,
    "baseUrl": "src",
    "paths": {
      "database": ["../../prisma/index.ts"],
      "shared": ["../../shared/index.ts"],
      "shared/transformer": ["../../shared/transformer.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules"]
}
